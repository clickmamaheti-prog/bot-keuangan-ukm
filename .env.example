# Bot Laporan Keuangan UKM
# Copy file ini ke .env dan isi value-nya

# Telegram Bot Token (dapat dari @BotFather)
TELEGRAM_BOT_TOKEN=isi_token_kamu_disini

# Database URL (PostgreSQL dari Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin Telegram ID (kamu)
ADMIN_TELEGRAM_ID=123456789

# Harga Premium per bulan
PREMIUM_PRICE=50000

# Nomor Rekening untuk pembayaran
BANK_NAME=BCA
BANK_ACCOUNT=1234567890
BANK_HOLDER=DevCultur XII

# QRIS Image URL (opsional)
QRIS_IMAGE_URL=
